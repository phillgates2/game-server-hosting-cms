# ============================================
# GamePanel Environment Configuration
# ============================================
# Copy this file to .env and update the values
# cp .env.example .env
# ============================================

# ─── Database Configuration ───
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://gamepanel:your_password@127.0.0.1:5432/gamepanel_db"

# ─── Application Settings ───
# Environment: development, production, test
NODE_ENV=production

# Port to run the application on (default: 3000)
PORT=3000

# ─── Security ───
# JWT Secret for authentication tokens
# Generate with: openssl rand -base64 32
# IMPORTANT: Use a unique, random string in production!
JWT_SECRET="change-this-to-a-random-32-character-string-minimum"

# ─── Optional: Domain Configuration ───
# Uncomment and set your domain for production
# NEXT_PUBLIC_APP_URL=https://panel.yourdomain.com

# ─── Optional: Email Configuration (for future use) ───
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@yourdomain.com
# SMTP_PASS=your_smtp_password
# SMTP_FROM="GamePanel <noreply@yourdomain.com>"

# ─── Optional: External Services (for future use) ───
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx
# PTERODACTYL_URL=https://panel.example.com
# PTERODACTYL_API_KEY=your_api_key
